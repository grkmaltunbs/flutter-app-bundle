android/.gradle/
android/local.properties

# Secrets — never commit
android/key.properties
*.keystore
*.jks
**/*service-account*.json
*.env

# Autobuild runner — generated at runtime in the target project
autobuild.log
.autobuild-stop
AUTOBUILD_NEEDS_HUMAN.md
runner/__pycache__/
runner/.venv/
